#!/usr/bin/env python3
"""Dependency-free Evergreen command-line entry point."""

import argparse
import json
from pathlib import Path
import sys


sys.dont_write_bytecode = True
PLUGIN_ROOT = Path(__file__).resolve().parents[1]
if str(PLUGIN_ROOT) not in sys.path:
    sys.path.insert(0, str(PLUGIN_ROOT))

from evergreen.evidence import load_evidence  # noqa: E402
from evergreen.impact import impact  # noqa: E402


def error_display(value):
    rendered = ascii(str(value))
    return rendered if len(rendered) <= 512 else rendered[:508] + "...'"


def terminal_display(value, limit=4096):
    pieces = []
    used = 0
    for character in str(value):
        piece = character if character.isprintable() else character.encode(
            "unicode_escape", errors="backslashreplace"
        ).decode("ascii")
        if used + len(piece) > limit:
            pieces.append("...")
            break
        pieces.append(piece)
        used += len(piece)
    return "".join(pieces)


def parser():
    root = argparse.ArgumentParser(
        prog="evergreen",
        description="Evergreen candidate queries and reversible host setup.",
    )
    commands = root.add_subparsers(dest="command", required=True)
    query = commands.add_parser(
        "impact", help="find documentation candidates for changed paths and passive evidence"
    )
    query.add_argument("--repo", default=".", help="repository root (default: current directory)")
    query.add_argument("--evidence", help="passive evidence-provider JSON file")
    query.add_argument("--json", action="store_true", help="emit one JSON object")
    query.add_argument("paths", metavar="PATH", nargs="*", help="changed repository-relative path")
    query.set_defaults(run=run_impact)
    for name, help_text, runner in (
        ("install", "install reversible Claude or Codex integration", run_install),
        ("uninstall", "remove only Evergreen-owned host integration", run_uninstall),
    ):
        command = commands.add_parser(name, help=help_text)
        command.add_argument("--host", choices=("claude", "codex", "all"), default="all")
        command.add_argument("--dry-run", action="store_true", help="describe changes only")
        command.set_defaults(run=runner)
    check = commands.add_parser("doctor", help="check canonical files and host ownership")
    check.add_argument("--host", choices=("claude", "codex", "all"), default="all")
    check.add_argument("--repo", default=str(PLUGIN_ROOT), help="canonical Evergreen root")
    check.set_defaults(run=run_doctor)
    return root


def run_install(args):
    from evergreen.hosts import install
    return _print_operation(install(Path.home(), PLUGIN_ROOT, args.host, args.dry_run), 2)


def run_uninstall(args):
    from evergreen.hosts import uninstall
    return _print_operation(uninstall(Path.home(), args.host, args.dry_run), 2)


def run_doctor(args):
    from evergreen.hosts import doctor
    result = doctor(Path.home(), Path(args.repo).expanduser(), args.host)
    code = _print_operation(result, 1)
    if result.ok:
        print("Evergreen host setup is healthy.")
    return code


def _print_operation(result, failure_code):
    stream = sys.stdout if result.ok else sys.stderr
    for message in result.messages:
        print(terminal_display(message), file=stream)
    return 0 if result.ok else failure_code


def run_impact(args):
    repo = Path(args.repo).expanduser()
    if not repo.is_dir():
        print(f"evergreen: repository must be a directory: {error_display(repo)}", file=sys.stderr)
        return 2
    repo = repo.resolve()

    evidence = []
    warnings = []
    if args.evidence is not None:
        evidence, evidence_warnings = load_evidence(Path(args.evidence), repo)
        warnings.extend(evidence_warnings)
    report = impact(repo, args.paths, evidence)
    warnings.extend(report.warnings)
    warnings = sorted(set(warnings))
    payload = {
        "schema_version": 1,
        "candidates": [
            {"path": item.path, "rank": item.rank, "reasons": list(item.reasons)}
            for item in report.candidates
        ],
        "warnings": warnings,
    }
    if args.json:
        print(json.dumps(payload, ensure_ascii=False, separators=(",", ":"), sort_keys=True))
    else:
        print_human(payload)
    return 0


def print_human(payload):
    candidates = payload["candidates"]
    print(f"Candidates ({len(candidates)}):")
    if not candidates:
        print("- none")
    for candidate in candidates:
        print(f"- [{candidate['rank']}] {terminal_display(candidate['path'])}")
        for reason in candidate["reasons"]:
            print(f"  reason: {terminal_display(reason)}")
    warnings = payload["warnings"]
    if warnings:
        print(f"Warnings ({len(warnings)}):")
        for warning in warnings:
            print(f"- {terminal_display(warning)}")


def main(argv=None):
    arguments = parser().parse_args(argv)
    try:
        return arguments.run(arguments)
    except (OSError, UnicodeError) as error:
        print(f"evergreen: {error_display(error)}", file=sys.stderr)
        return 1


if __name__ == "__main__":
    raise SystemExit(main())
