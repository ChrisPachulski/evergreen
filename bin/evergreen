#!/usr/bin/env python3
"""Dependency-free Evergreen command-line entry point."""

import argparse
import json
from pathlib import Path
import sys


sys.dont_write_bytecode = True
PLUGIN_ROOT = Path(__file__).resolve().parents[1]
if str(PLUGIN_ROOT) not in sys.path:
    sys.path.insert(0, str(PLUGIN_ROOT))

from evergreen.evidence import load_evidence  # noqa: E402
from evergreen.impact import impact  # noqa: E402


def error_display(value):
    rendered = ascii(str(value))
    return rendered if len(rendered) <= 512 else rendered[:508] + "...'"


def terminal_display(value, limit=4096):
    pieces = []
    used = 0
    for character in str(value):
        piece = character if character.isprintable() else character.encode(
            "unicode_escape", errors="backslashreplace"
        ).decode("ascii")
        if used + len(piece) > limit:
            pieces.append("...")
            break
        pieces.append(piece)
        used += len(piece)
    return "".join(pieces)


def parser():
    root = argparse.ArgumentParser(
        prog="evergreen",
        description="Evergreen candidate queries and reversible host setup.",
    )
    commands = root.add_subparsers(dest="command", required=True)
    query = commands.add_parser(
        "impact", help="find documentation candidates for changed paths and passive evidence"
    )
    query.add_argument("--repo", default=".", help="repository root (default: current directory)")
    query.add_argument("--evidence", help="passive evidence-provider JSON file")
    query.add_argument("--json", action="store_true", help="emit one JSON object")
    query.add_argument("paths", metavar="PATH", nargs="*", help="changed repository-relative path")
    query.set_defaults(run=run_impact)
    receipt = commands.add_parser("receipt", help="emit evidence-backed repository state")
    receipt.add_argument("--repo", default=".", help="path inside a Git repository")
    receipt.add_argument("--benchmark-manifest", help="Evergreen public benchmark manifest")
    receipt.add_argument("--json", action="store_true", help="emit one JSON object")
    receipt.set_defaults(run=run_receipt)
    grade = commands.add_parser("grade", help="verify a trusted evidence package")
    grade_commands = grade.add_subparsers(dest="grade_command", required=True)
    verify = grade_commands.add_parser(
        "verify", help="verify evidence earned an A grade"
    )
    verify.add_argument(
        "--repo", metavar="PATH", required=True,
        help="repository containing committed evidence",
    )
    verify.add_argument(
        "--manifest", metavar="PATH", required=True,
        help="repository-relative evidence manifest",
    )
    verify.add_argument("--json", action="store_true", help="emit one JSON object")
    verify.set_defaults(run=run_grade_verify)
    for name, help_text, runner in (
        ("install", "install reversible Claude or Codex integration", run_install),
        ("uninstall", "remove only Evergreen-owned host integration", run_uninstall),
    ):
        command = commands.add_parser(name, help=help_text)
        command.add_argument("--host", choices=("claude", "codex", "all"), default="all")
        command.add_argument("--dry-run", action="store_true", help="describe changes only")
        command.set_defaults(run=runner)
    check = commands.add_parser("doctor", help="check canonical files and host ownership")
    check.add_argument("--host", choices=("claude", "codex", "all"), default="all")
    check.add_argument("--repo", default=str(PLUGIN_ROOT), help="canonical Evergreen root")
    check.set_defaults(run=run_doctor)
    return root


def run_install(args):
    from evergreen.hosts import install
    return _print_operation(install(Path.home(), PLUGIN_ROOT, args.host, args.dry_run), 2)


def run_uninstall(args):
    from evergreen.hosts import uninstall
    return _print_operation(uninstall(Path.home(), args.host, args.dry_run), 2)


def run_doctor(args):
    from evergreen.hosts import doctor
    result = doctor(Path.home(), Path(args.repo).expanduser(), args.host)
    code = _print_operation(result, 1)
    if result.ok:
        print("Evergreen host setup is healthy.")
    return code


def _print_operation(result, failure_code):
    stream = sys.stdout if result.ok else sys.stderr
    for message in result.messages:
        print(terminal_display(message), file=stream)
    return 0 if result.ok else failure_code


def run_impact(args):
    repo = Path(args.repo).expanduser()
    if not repo.is_dir():
        print(f"evergreen: repository must be a directory: {error_display(repo)}", file=sys.stderr)
        return 2
    repo = repo.resolve()

    evidence = []
    warnings = []
    if args.evidence is not None:
        evidence, evidence_warnings = load_evidence(Path(args.evidence), repo)
        warnings.extend(evidence_warnings)
    report = impact(repo, args.paths, evidence)
    warnings.extend(report.warnings)
    warnings = sorted(set(warnings))
    payload = {
        "schema_version": 1,
        "candidates": [
            {"path": item.path, "rank": item.rank, "reasons": list(item.reasons)}
            for item in report.candidates
        ],
        "warnings": warnings,
    }
    if args.json:
        print(json.dumps(payload, ensure_ascii=False, separators=(",", ":"), sort_keys=True))
    else:
        print_human(payload)
    return 0


def run_receipt(args):
    from evergreen.receipt import ReceiptError, ReceiptOperationalError, build_receipt

    try:
        repo = Path(args.repo).expanduser()
        benchmark_manifest = (
            None
            if args.benchmark_manifest is None
            else Path(args.benchmark_manifest).expanduser()
        )
    except (OSError, RuntimeError) as error:
        print(f"evergreen: {error_display(error)}", file=sys.stderr)
        return 2
    try:
        payload = build_receipt(repo, benchmark_manifest)
    except ReceiptOperationalError as error:
        print(f"evergreen: {error_display(error)}", file=sys.stderr)
        return 1
    except ReceiptError as error:
        print(f"evergreen: {error_display(error)}", file=sys.stderr)
        return 2
    if args.json:
        print(json.dumps(payload, ensure_ascii=False, separators=(",", ":"), sort_keys=True))
    else:
        print_receipt(payload)
    return 0


def run_grade_verify(args):
    from evergreen.grade import (
        canonical_receipt,
        verification_exit_code,
        verify_repository,
    )
    from evergreen.receipt import ReceiptOperationalError

    try:
        repo = Path(args.repo).expanduser()
        payload = verify_repository(repo, args.manifest, PLUGIN_ROOT)
    except ReceiptOperationalError as error:
        print(f"evergreen: {error_display(error)}", file=sys.stderr)
        return 1
    if args.json:
        sys.stdout.buffer.write(canonical_receipt(payload))
    else:
        print_grade_verification(payload)
    return verification_exit_code(payload)


def print_grade_verification(payload):
    print("Evergreen grade verification:")
    print(f"- status: {terminal_display(payload['status'])}")
    grade = "none" if payload.get("grade") is None else payload["grade"]
    print(f"- grade: {terminal_display(grade)}")
    subject = payload.get("subject")
    if subject is not None:
        print(f"- subject: {terminal_display(subject['commit'])}")
    evidence_head = payload.get("evidence_head")
    if evidence_head is not None:
        print(f"- evidence HEAD: {terminal_display(evidence_head['commit'])}")
    verifier = payload["verifier"]
    print(f"- verifier commit: {terminal_display(verifier['commit'])}")
    print(f"- verifier tree: {terminal_display(verifier['tree'])}")
    print(f"- verifier artifact SHA-256: {terminal_display(verifier['artifact_sha256'])}")
    categories = payload.get("categories", [])
    if categories:
        print("Categories:")
        for category in categories:
            print(
                f"- {terminal_display(category['id'])}: "
                f"{terminal_display(category['status'])}"
            )
            for reason in category["reasons"]:
                print(f"  reason: {terminal_display(reason)}")
    failures = payload.get("failures", [])
    if failures:
        print("Failures:")
        for failure in failures:
            print(
                f"- {terminal_display(failure['code'])}: "
                f"{terminal_display(failure['detail'])}"
            )


def print_receipt(payload):
    repository = payload["repository"]
    print("Repository receipt:")
    print(f"- root: {terminal_display(repository['root'])}")
    print(f"- name: {terminal_display(repository['name'])}")
    print("- origin: " + (
        "none" if repository["origin"] is None else terminal_display(repository["origin"])
    ))
    print("- branch: " + (
        "detached" if repository["branch"] is None else terminal_display(repository["branch"])
    ))
    print(f"- HEAD: {terminal_display(repository['head'])}")
    print("- upstream: " + (
        "none" if repository["upstream"] is None else terminal_display(repository["upstream"])
    ))
    ahead_behind = (
        "unknown"
        if repository["ahead"] is None or repository["behind"] is None
        else f"{repository['ahead']}/{repository['behind']}"
    )
    print(f"- ahead/behind: {ahead_behind}")
    print(
        f"- changes: staged={repository['staged']} "
        f"unstaged={repository['unstaged']} untracked={repository['untracked']}"
    )
    print(f"- clean: {str(repository['clean']).lower()}")

    release = payload["release"]
    tags = "none" if not release["local_tags"] else terminal_display(
        ",".join(release["local_tags"])
    )
    print("Release evidence:")
    print(f"- local tags at HEAD: {tags}")
    print(f"- external state: {terminal_display(release['external_state'])}")

    benchmark = payload["benchmark"]
    print("Benchmark evidence:")
    if benchmark is None:
        print("- none")
        return
    print(f"- artifact count: {benchmark['artifact_count']}")
    print(f"- evaluated release: {terminal_display(benchmark['evaluated_release'])}")
    print(f"- evidence state: {terminal_display(benchmark['evidence_state'])}")
    print(f"- judge SHA-256: {terminal_display(benchmark['judge_sha256'])}")
    print(f"- languages: {terminal_display(','.join(benchmark['languages']))}")
    print(f"- manifest: {terminal_display(benchmark['manifest'])}")
    print(f"- protocol: {terminal_display(benchmark['protocol'])}")
    print(f"- provenance commit: {terminal_display(benchmark['provenance_commit'])}")
    print(f"- provider: {terminal_display(benchmark['provider'])}")
    print(f"- report: {terminal_display(benchmark['report'])}")
    print(f"- resolver: {terminal_display(benchmark['resolver'])}")


def print_human(payload):
    candidates = payload["candidates"]
    print(f"Candidates ({len(candidates)}):")
    if not candidates:
        print("- none")
    for candidate in candidates:
        print(f"- [{candidate['rank']}] {terminal_display(candidate['path'])}")
        for reason in candidate["reasons"]:
            print(f"  reason: {terminal_display(reason)}")
    warnings = payload["warnings"]
    if warnings:
        print(f"Warnings ({len(warnings)}):")
        for warning in warnings:
            print(f"- {terminal_display(warning)}")


def main(argv=None):
    arguments = parser().parse_args(argv)
    try:
        return arguments.run(arguments)
    except (OSError, UnicodeError) as error:
        print(f"evergreen: {error_display(error)}", file=sys.stderr)
        return 1


if __name__ == "__main__":
    raise SystemExit(main())
