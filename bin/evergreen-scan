#!/usr/bin/env bash
# evergreen-scan — deterministic, zero-LLM documentation-drift detector.
# Portable (bash 3.2+, git, grep, awk). Runs in any repo, any language.
#
# Signals (cheapest, most-reliable first — see docs/DESIGN.md for prior-art credit):
#   1. doc-named path existence  : a path a doc names but that no longer exists  -> in_docs_not_code
#   2. rename cross-reference    : a doc still cites a path git just renamed/deleted -> in_docs_not_code
#   3. contract existence        : a CLI flag/env var a doc documents but no code uses -> in_docs_not_code
#   4. runnable example (opt-in) : a fenced block tagged `evergreen` that exits nonzero -> in_docs_not_code
#
# Exit: 0 = clean; 2 = findings at/above --fail-level (for hooks/CI); 1 = usage/error.
# NB: no `set -e`/`pipefail` — grep returns 1 on no-match (normal here); exit codes are explicit.
set -u

BASE=""                       # git ref to diff against (default: auto)
MODE="human"                  # human | json
FAIL_LEVEL="high"             # none|low|medium|high — min severity that exits nonzero in --ci
CI=0
RUN_EXAMPLES=0                # rung-4 example execution runs code: OFF unless --run-examples
LOGFILE=""                    # --log FILE: append findings as a JSONL audit trail
SCORE=0                       # --score: also print a freshness_pct
COVERAGE=0                    # --coverage: doc-comment coverage mode (completeness, not drift)
FAIL_UNDER=80                 # --fail-under N: coverage % below which --ci exits 2
FIX=0                         # --fix: apply derivable fixes (embed refresh, manifest re-pin)
# Doc files we gate.
DOC_GLOB='(^|/)(README|CHANGELOG|CONTRIBUTING)[^/]*\.(md|markdown)$|(^|/)docs?/.*\.(md|markdown|rst)$'
# A doc-named path is only validated if it (a) starts with a REAL top-level tracked
# dir in THIS repo (kills URL paths like api/iptv/health, frameworks like lib/CryptoKit,
# and sibling-repo refs like server/routes/x.ts) AND (b) looks like a file (known
# extension). This is the false-positive discipline: a noisy detector gets ignored.
EXT='\.(swift|ts|tsx|js|jsx|mjs|cjs|rs|go|py|rb|java|kt|kts|c|h|cc|cpp|hpp|m|mm|cs|php|scala|ex|exs|md|markdown|rst|ya?ml|json|toml|sh|bash|sql|proto|graphql)$'
# Doc subtrees that are aspirational by nature and exempt from gating (ponytail: specs lead code).
EXEMPT='/specs?/|/adr/|/rfcs?/|/proposals?/'

usage(){ echo "usage: evergreen-scan [--base REF] [--json|--sarif] [--ci] [--fail-level L] [--score] [--log FILE] [--run-examples] [--fix] [--coverage [--fail-under N]] [--selftest]"; exit 1; }
[ -f .evergreen.sh ] && . ./.evergreen.sh   # optional per-repo overrides

while [ $# -gt 0 ]; do case "$1" in
  --base) [ $# -ge 2 ] || usage; BASE="$2"; shift 2;;
  --json) MODE="json"; shift;;
  --sarif) MODE="sarif"; shift;;
  --ci) CI=1; shift;;
  --fail-level) [ $# -ge 2 ] || usage; FAIL_LEVEL="$2"; shift 2;;
  --score) SCORE=1; shift;;
  --log) [ $# -ge 2 ] || usage; LOGFILE="$2"; shift 2;;
  --coverage) COVERAGE=1; shift;;
  --fail-under) [ $# -ge 2 ] || usage; FAIL_UNDER="$2"; shift 2;;
  --fix) FIX=1; shift;;
  --run-examples) RUN_EXAMPLES=1; shift;;
  --selftest) shift; exec "$0" __selftest "$@";;
  __selftest) RUN_SELFTEST=1; shift;;
  -h|--help) usage;;
  *) echo "unknown arg: $1" >&2; usage;;
esac; done
# A typo'd fail-level must not silently mean "high"; fail-under must be an integer.
case "$FAIL_LEVEL" in none|low|medium|high) ;; *) echo "bad --fail-level: $FAIL_LEVEL (want none|low|medium|high)" >&2; exit 1;; esac
case "$FAIL_UNDER" in ''|*[!0-9]*) echo "bad --fail-under: $FAIL_UNDER (want integer)" >&2; exit 1;; esac

sev_rank(){ case "$1" in none) echo 0;; low) echo 1;; medium) echo 2;; high) echo 3;; *) echo 3;; esac; }

# ---- finding sink: category \t severity \t file \t detail ------------------
# TSV is the sink, so a TAB/newline in any field (e.g. a tab in a tracked filename)
# would corrupt the column split — squash them to spaces before writing.
FIND="$(mktemp)"; trap 'rm -f "$FIND"' EXIT
emit(){ printf '%s\t%s\t%s\t%s\n' "${1//[$'\t\n']/ }" "${2//[$'\t\n']/ }" "${3//[$'\t\n']/ }" "${4//[$'\t\n']/ }" >> "$FIND"; }

default_base(){
  if [ -n "$BASE" ]; then echo "$BASE"; return; fi
  if git rev-parse --verify -q origin/main >/dev/null; then echo origin/main
  elif git rev-parse --verify -q HEAD~1 >/dev/null; then echo HEAD~1
  else echo ""; fi
}

# Gated doc files, NUL-delimited — a tracked doc path may contain spaces/globs; never
# word-split it (a skipped file would print a FALSE "clean"). Consumers: read -r -d ''.
doc_files_z(){ git ls-files -z | grep -zEi "$DOC_GLOB" | grep -zEv "$EXEMPT" || true; }

# Real top-level tracked dirs in THIS repo (override CODE_ROOTS in .evergreen.sh to pin).
top_roots(){ if [ -n "${CODE_ROOTS:-}" ]; then echo "$CODE_ROOTS"; else git ls-files | awk -F/ 'NF>1{print $1}' | sort -u | paste -sd'|' -; fi; }

# Signal 1: every file-like, in-repo path a doc names must exist on disk (or be tracked).
scan_path_existence(){
  local doc p roots; roots="$(top_roots)"; [ -n "$roots" ] || return 0
  while IFS= read -r -d '' doc; do
    grep -oE "($roots)/[A-Za-z0-9_./-]+" "$doc" 2>/dev/null | sort -u | while read -r p; do
      p="${p%%[).,\`\"]}"; case "$p" in */) p="${p%/}";; esac
      printf '%s' "$p" | grep -qiE "$EXT" || continue          # must look like a file
      [ -e "$p" ] && continue                                   # exists on disk
      git ls-files --error-unmatch "$p" >/dev/null 2>&1 && continue  # tracked
      emit in_docs_not_code high "$doc" "names \`$p\` which does not exist on disk"
    done
  done < <(doc_files_z)
}

# Signal 2: docs that still cite a path git renamed/deleted since BASE.
scan_renames(){
  local base="$1" status old new doc
  [ -n "$base" ] || return 0
  git diff --name-status --find-renames=50 "$base" HEAD 2>/dev/null | while IFS=$'\t' read -r status old new; do
    case "$status" in
      R*) while IFS= read -r -d '' doc; do grep -qF -- "$old" "$doc" 2>/dev/null && emit in_docs_not_code high "$doc" "cites \`$old\` which was renamed to \`$new\`"; done < <(doc_files_z);;
      D)  while IFS= read -r -d '' doc; do grep -qF -- "$old" "$doc" 2>/dev/null && emit in_docs_not_code high "$doc" "cites \`$old\` which was deleted"; done < <(doc_files_z);;
    esac
  done
}

# Signal 3: doc-documented CLI flags / env vars that no longer exist anywhere in code.
# Precision discipline (a noisy detector gets muted):
#  - only tokens inside `inline-code` spans count — prose UPPER_SNAKE (BOLD_TEXT) and
#    markdown rules/tables never reach the matcher; docs already backtick real flags/vars.
#  - flags are `--word` shaped; env/config tokens are UPPER_SNAKE *with* an underscore.
#  - existence is a WHOLE-TOKEN (boundary-aware) match against tracked NON-doc files, so
#    `--verbose` is NOT satisfied by `--verbose-mode` (that false-negative is the dangerous
#    direction for a zero-false-negative tool). A token living only in docs is drift.
# ponytail: O(tokens × files) grep; fine at repo scale, pre-filter if huge.
scan_contract(){
  local doc spans tok codelist
  codelist="$(mktemp)"; git ls-files -z 2>/dev/null | grep -zEiv "$DOC_GLOB" > "$codelist"
  [ -s "$codelist" ] || { rm -f "$codelist"; return 0; }
  in_code(){ [ -n "$(xargs -0 grep -lE -- "(^|[^A-Za-z0-9_-])$1([^A-Za-z0-9_-]|$)" < "$codelist" 2>/dev/null | head -1)" ]; }
  while IFS= read -r -d '' doc; do
    spans="$(grep -oE '`[^`]+`' "$doc" 2>/dev/null)"
    [ -n "$spans" ] || continue
    printf '%s\n' "$spans" | grep -oE -- '--[a-z][a-z0-9]+[a-z0-9-]*' | sort -u | while read -r tok; do
      [ -n "$tok" ] && { in_code "$tok" || emit in_docs_not_code high "$doc" "documents flag \`$tok\` not found in code"; }
    done
    printf '%s\n' "$spans" | grep -oE '\b[A-Z][A-Z0-9]*_[A-Z0-9_]+\b' | sort -u | while read -r tok; do
      [ -n "$tok" ] && { in_code "$tok" || emit in_docs_not_code medium "$doc" "documents env/config \`$tok\` not found in code"; }
    done
  done < <(doc_files_z)
  rm -f "$codelist"
}

# Signal 4 — RUNS CODE FROM THE DOC. OFF unless the operator passes --run-examples; the
# Stop hook NEVER passes it, so opening an untrusted repo can't auto-execute its README.
# Doc-author opt-in (a fence info string containing `evergreen`) is necessary but not
# sufficient — operator consent is required too. Execution gets a scrubbed env + scratch
# HOME/TMPDIR to shrink blast radius; this is NOT a sandbox (absolute paths/network still
# reach out). Only run --run-examples on docs you trust. A nonzero exit is drift.
scan_examples(){
  [ "$RUN_EXAMPLES" = 1 ] || return 0
  command -v bash >/dev/null 2>&1 || return 0
  local doc line trimmed inblk blk n rc tmp
  while IFS= read -r -d '' doc; do
    inblk=0; blk=""; n=0
    while IFS= read -r line; do
      trimmed="${line#"${line%%[![:space:]]*}"}"   # tolerate indented fences (CommonMark lists)
      case "$trimmed" in
        '```'*evergreen*) inblk=1; blk=""; n=$((n+1)); continue;;
        '```'*) [ "$inblk" = 1 ] || continue
                inblk=0; tmp="$(mktemp -d)"; rc=0
                ( cd "$tmp" && env -i HOME="$tmp" TMPDIR="$tmp" PATH="$PATH" bash -c "$blk" ) >/dev/null 2>&1 || rc=$?
                rm -rf "$tmp"
                [ "$rc" -ne 0 ] && emit in_docs_not_code high "$doc" "runnable example #$n exits nonzero ($rc)"
                continue;;
      esac
      [ "$inblk" = 1 ] && blk="$blk$line
"
    done < "$doc"
  done < <(doc_files_z)
}

# Signal 5: embed-from-source. A doc pins a fenced block to a source range with a marker
#   <!-- evergreen:embed path/to/src.rs:10-20 -->
#   ```rust
#   ...lines 10-20 of src.rs...
#   ```
# If the block no longer matches those source lines, it has drifted. `--fix` rewrites the
# block from source — a snippet that is regenerated can't silently lie.
embed_source(){ [ -f "$1" ] || return 1; awk -v s="$2" -v e="$3" 'NR>=s&&NR<=e' "$1"; }

# Parse one doc, comparing each embed block against its source range (mode=check) or
# rewriting it from source (mode=fix). Shared 3-state machine: 0 normal, 1 awaiting the
# opening fence, 2 inside the block body.
embed_one(){
  local doc="$1" mode="$2" line spec src rng start end want body exp tmp
  want=0; body=""; tmp="$(mktemp)"
  while IFS= read -r line; do
    case $want in
      0) [ "$mode" = fix ] && printf '%s\n' "$line" >> "$tmp"
         case "$line" in *'evergreen:embed'*)
            spec="$(printf '%s' "$line" | sed -E 's/.*evergreen:embed +([^ ]+).*/\1/')"
            src="${spec%%:*}"; rng="${spec#*:}"; start="${rng%%-*}"; end="${rng#*-}"
            [ "$end" = "$rng" ] && end="$start"
            case "$start$end" in ''|*[!0-9]*) want=0;; *) want=1;; esac;;
         esac;;
      1) [ "$mode" = fix ] && printf '%s\n' "$line" >> "$tmp"
         case "$line" in '```'*) want=2; body="";; '') ;; *) want=0;; esac;;
      2) case "$line" in
           '```'*)
             if exp="$(embed_source "$src" "$start" "$end")"; then
               [ "$mode" = check ] && { [ "${body%$'\n'}" != "$exp" ] && emit in_docs_not_code high "$doc" "embedded snippet from \`$src:$start-$end\` has drifted from source"; }
               [ "$mode" = fix ] && printf '%s\n' "$exp" >> "$tmp"
             else
               [ "$mode" = check ] && emit in_docs_not_code high "$doc" "embed source \`$src\` missing or range $start-$end invalid"
               [ "$mode" = fix ] && printf '%s' "$body" >> "$tmp"
             fi
             [ "$mode" = fix ] && printf '%s\n' "$line" >> "$tmp"
             want=0;;
           *) body="$body$line
"; [ "$mode" = fix ] || : ;;
         esac;;
    esac
  done < "$doc"
  if [ "$mode" = fix ] && ! cmp -s "$tmp" "$doc"; then cp "$tmp" "$doc"; echo "fixed (embed): $doc" >&2; fi
  rm -f "$tmp"
}

scan_embed(){ while IFS= read -r -d '' doc; do embed_one "$doc" check; done < <(doc_files_z); }

# --fix applies ONLY derivable fixes (embed refresh from source; manifest re-pin). It
# never rewrites prose — that stays a human/model job. Fix messages go to stderr so
# --json/--sarif stdout stays clean.
do_fix(){
  local doc
  while IFS= read -r -d '' doc; do embed_one "$doc" fix; done < <(doc_files_z)
}

run_scan(){
  local base; base="$(default_base)"
  scan_path_existence
  scan_renames "$base"
  scan_contract
  scan_embed
  scan_examples
}

# freshness_pct: 100 minus a severity-weighted penalty (high 15, med 5, low 2), floored at 0.
# Deterministic and monotonic — more/worse drift can only lower it. Empty findings -> 100.
compute_score(){ awk -F'\t' '{if($2=="high")h++;else if($2=="medium")m++;else l++} END{s=100-(h*15+m*5+l*2); if(s<0)s=0; print s}' "$FIND"; }

# Append each finding as one JSON object to the --log file: a cross-session audit trail.
log_jsonl(){
  [ -n "$LOGFILE" ] || return 0
  local ts; ts="$(date -u +%FT%TZ 2>/dev/null || echo "")"
  awk -F'\t' -v ts="$ts" 'function j(s){gsub(/\\/,"\\\\",s);gsub(/"/,"\\\"",s);return s}
    {printf "{\"ts\":\"%s\",\"category\":\"%s\",\"severity\":\"%s\",\"file\":\"%s\",\"detail\":\"%s\"}\n", ts, j($1), j($2), j($3), j($4)}' "$FIND" >> "$LOGFILE"
}

render_sarif(){
  printf '{"version":"2.1.0","$schema":"https://json.schemastore.org/sarif-2.1.0.json","runs":[{"tool":{"driver":{"name":"evergreen","informationUri":"https://github.com/","rules":[]}},"results":['
  awk -F'\t' 'function j(s){gsub(/\\/,"\\\\",s);gsub(/"/,"\\\"",s);return s}
    {lvl=($2=="high")?"error":(($2=="medium")?"warning":"note");
     printf "%s{\"ruleId\":\"%s\",\"level\":\"%s\",\"message\":{\"text\":\"%s\"},\"locations\":[{\"physicalLocation\":{\"artifactLocation\":{\"uri\":\"%s\"}}}]}", (NR>1?",":""), j($1), lvl, j($4), j($3)}' "$FIND"
  printf ']}]}\n'
}

render(){
  log_jsonl
  local total pct; total=$(wc -l < "$FIND" | tr -d ' '); pct="$(compute_score)"
  case "$MODE" in
    json)
      printf '{"findings":['
      awk -F'\t' 'function j(s){gsub(/\\/,"\\\\",s);gsub(/"/,"\\\"",s);return s}
        NR>1{printf ","} {printf "{\"category\":\"%s\",\"severity\":\"%s\",\"file\":\"%s\",\"detail\":\"%s\"}", j($1),j($2),j($3),j($4)}' "$FIND"
      printf '],"count":%s,"freshness_pct":%s}\n' "$total" "$pct"
      ;;
    sarif) render_sarif ;;
    *)
      if [ "$total" -eq 0 ]; then echo "✓ evergreen: no drift detected"; else
        echo "evergreen: $total finding(s)"
        sort -t$'\t' -k1,1 "$FIND" | while IFS=$'\t' read -r c s f d; do
          printf "  [%s] %-18s %s — %s\n" "$s" "$c" "$f" "$d"
        done
      fi
      [ "$SCORE" -eq 1 ] && echo "freshness: ${pct}% (100 = no drift)"
      ;;
  esac
  # exit code for --ci
  if [ "$CI" -eq 1 ]; then
    local need worst; need=$(sev_rank "$FAIL_LEVEL"); worst=0
    while IFS=$'\t' read -r c s f d; do [ "$(sev_rank "$s")" -ge "$need" ] && worst=1; done < "$FIND"
    if [ "$worst" -eq 1 ]; then exit 2; fi
  fi
}

# ---- self-test: build a throwaway repo with known drift, assert detection ----
selftest(){
  local t; t="$(mktemp -d)"; ( cd "$t" || exit 1
    git init -q; git config user.email t@t; git config user.name t
    mkdir -p src docs
    {                                                  # code contains these whole tokens:
      printf 'let x = "--real-flag"\n'                  #   --real-flag (must NOT flag)
      printf '// also --verbose-mode here\n'            #   --verbose-mode (so --verbose must NOT substring-match)
      printf 'REAL_VAR=1\n'                             #   REAL_VAR (must NOT flag)
      printf 'API_KEY_SECRET=2\n'                       #   API_KEY_SECRET (so API_KEY must NOT substring-match)
    } > src/keep.swift
    {
      printf '# Doc\n'
      printf 'See `src/keep.swift` and `src/GONE.swift`.\n'      # rung 1: GONE.swift missing
      printf 'Run with `--real-flag` or `--ghost-flag`.\n'        # rung 3: --ghost-flag absent
      printf 'Also `--verbose` (only --verbose-mode exists).\n'   # rung 3: boundary -> --verbose IS drift
      printf 'Set `REAL_VAR` but not `GHOST_VAR` or `API_KEY`.\n' # rung 3: GHOST_VAR + API_KEY are drift
      printf 'Prose MAX_SIZE and BOLD_TEXT are not code.\n'       # no backticks -> must NOT flag
      printf '\n```bash evergreen\nexit 7\n```\n'                 # rung 4: opt-in block fails
    } > docs/guide.md
    git add -A; git commit -qm init
    git mv src/keep.swift src/renamed.swift; git commit -qm rename
  )
  local out; out="$(cd "$t" && bash "$SELF" --base HEAD~1 --run-examples 2>/dev/null || true)"
  rm -rf "$t"
  echo "$out" | grep -q "GONE.swift"     || { echo "FAIL: missing path-existence drift"; echo "$out"; exit 1; }
  echo "$out" | grep -q "renamed"        || { echo "FAIL: missing rename drift"; echo "$out"; exit 1; }
  echo "$out" | grep -q -- "--ghost-flag" || { echo "FAIL: missing flag-contract drift"; echo "$out"; exit 1; }
  echo "$out" | grep -q -- "--verbose\`"  || { echo "FAIL: boundary false-negative (--verbose vs --verbose-mode)"; echo "$out"; exit 1; }
  echo "$out" | grep -q "GHOST_VAR"      || { echo "FAIL: missing env-contract drift"; echo "$out"; exit 1; }
  echo "$out" | grep -q "API_KEY\`"      || { echo "FAIL: boundary false-negative (API_KEY vs API_KEY_SECRET)"; echo "$out"; exit 1; }
  echo "$out" | grep -q "example #1"     || { echo "FAIL: missing runnable-example drift"; echo "$out"; exit 1; }
  echo "$out" | grep -q -- "--real-flag" && { echo "FAIL: false positive on --real-flag"; echo "$out"; exit 1; }
  echo "$out" | grep -q "REAL_VAR"       && { echo "FAIL: false positive on REAL_VAR"; echo "$out"; exit 1; }
  echo "$out" | grep -qE "MAX_SIZE|BOLD_TEXT" && { echo "FAIL: false positive on prose (non-backticked) token"; echo "$out"; exit 1; }
  echo "✓ selftest passed (path + rename + boundary-contract + opt-in example, no prose/substring false positives)"
}

SELF="$(cd "$(dirname "$0")" && pwd)/$(basename "$0")"
if [ "${RUN_SELFTEST:-0}" = 1 ]; then selftest; exit 0; fi
# Never report "clean" when we could not actually run: a false green is worse than a miss.
git rev-parse --is-inside-work-tree >/dev/null 2>&1 || { echo "evergreen: not a git repository — cannot scan (run inside a repo)" >&2; exit 1; }
if [ "$COVERAGE" -eq 1 ]; then run_coverage; exit $?; fi
[ "$FIX" -eq 1 ] && do_fix
run_scan
render
exit 0
