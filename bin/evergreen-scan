#!/usr/bin/env bash
# evergreen-scan — deterministic, zero-LLM documentation-drift detector.
# Portable (bash 3.2+, git, grep, awk). Runs in any repo, any language.
#
# Signals (cheapest, most-reliable first — see docs/DESIGN.md for prior-art credit):
#   1. doc-named path existence  : a path a doc names but that no longer exists  -> in_docs_not_code
#   2. rename cross-reference    : a doc still cites a path git just renamed/deleted -> in_docs_not_code
#   3. contract existence        : a CLI flag/env var a doc documents but no code uses -> in_docs_not_code
#   4. runnable example (opt-in) : a fenced block tagged `evergreen` that exits nonzero -> in_docs_not_code
#
# Exit: 0 = clean; 2 = findings at/above --fail-level (for hooks/CI); 1 = usage/error.
# NB: no `set -e`/`pipefail` — grep returns 1 on no-match (normal here); exit codes are explicit.
set -u

BASE=""                       # git ref to diff against (default: auto)
MODE="human"                  # human | json
FAIL_LEVEL="high"             # none|low|medium|high — min severity that exits nonzero in --ci
CI=0
RUN_EXAMPLES=0                # rung-4 example execution runs code: OFF unless --run-examples
LOGFILE=""                    # --log FILE: append findings as a JSONL audit trail
SCORE=0                       # --score: also print a freshness_pct
COVERAGE=0                    # --coverage: doc-comment coverage mode (completeness, not drift)
FAIL_UNDER=80                 # --fail-under N: coverage % below which --ci exits 2
BADGE=0                       # --badge: inject a shields.io coverage badge into README.md
FIX=0                         # --fix: apply derivable fixes (embed refresh, manifest re-pin)
FIX_PROSE=0                   # --fix-prose: LLM-draft + validate fixes for dead-path prose (opt-in, needs claude)
# Doc files we gate.
DOC_GLOB='(^|/)(README|CHANGELOG|CONTRIBUTING)[^/]*\.(md|markdown)$|(^|/)docs?/.*\.(md|markdown|rst)$'
# A doc-named path is only validated if it (a) starts with a REAL top-level tracked
# dir in THIS repo (kills URL paths like api/iptv/health, frameworks like lib/CryptoKit,
# and sibling-repo refs like server/routes/x.ts) AND (b) looks like a file (known
# extension). This is the false-positive discipline: a noisy detector gets ignored.
EXT='\.(swift|ts|tsx|js|jsx|mjs|cjs|rs|go|py|rb|java|kt|kts|c|h|cc|cpp|hpp|m|mm|cs|php|scala|ex|exs|md|markdown|rst|ya?ml|json|toml|sh|bash|sql|proto|graphql)$'
# Doc subtrees that are aspirational by nature and exempt from gating (ponytail: specs lead code).
EXEMPT='/specs?/|/adr/|/rfcs?/|/proposals?/'

usage(){ echo "usage: evergreen-scan [--base REF] [--json|--sarif] [--ci] [--fail-level L] [--score] [--log FILE] [--run-examples] [--fix] [--fix-prose] [--coverage [--fail-under N] [--badge]] [--selftest]"; exit 1; }
[ -f .evergreen.sh ] && . ./.evergreen.sh   # optional per-repo overrides

while [ $# -gt 0 ]; do case "$1" in
  --base) [ $# -ge 2 ] || usage; BASE="$2"; shift 2;;
  --json) MODE="json"; shift;;
  --sarif) MODE="sarif"; shift;;
  --ci) CI=1; shift;;
  --fail-level) [ $# -ge 2 ] || usage; FAIL_LEVEL="$2"; shift 2;;
  --score) SCORE=1; shift;;
  --log) [ $# -ge 2 ] || usage; LOGFILE="$2"; shift 2;;
  --coverage) COVERAGE=1; shift;;
  --fail-under) [ $# -ge 2 ] || usage; FAIL_UNDER="$2"; shift 2;;
  --badge) BADGE=1; shift;;
  --fix) FIX=1; shift;;
  --fix-prose) FIX_PROSE=1; shift;;
  --run-examples) RUN_EXAMPLES=1; shift;;
  --selftest) shift; exec "$0" __selftest "$@";;
  __selftest) RUN_SELFTEST=1; shift;;
  -h|--help) usage;;
  *) echo "unknown arg: $1" >&2; usage;;
esac; done
# A typo'd fail-level must not silently mean "high"; fail-under must be an integer.
case "$FAIL_LEVEL" in none|low|medium|high) ;; *) echo "bad --fail-level: $FAIL_LEVEL (want none|low|medium|high)" >&2; exit 1;; esac
case "$FAIL_UNDER" in ''|*[!0-9]*) echo "bad --fail-under: $FAIL_UNDER (want integer)" >&2; exit 1;; esac

sev_rank(){ case "$1" in none) echo 0;; low) echo 1;; medium) echo 2;; high) echo 3;; *) echo 3;; esac; }

# ---- finding sink: category \t severity \t file \t detail ------------------
# TSV is the sink, so a TAB/newline in any field (e.g. a tab in a tracked filename)
# would corrupt the column split — squash them to spaces before writing.
FIND="$(mktemp)"; trap 'rm -f "$FIND"' EXIT
emit(){ printf '%s\t%s\t%s\t%s\n' "${1//[$'\t\n']/ }" "${2//[$'\t\n']/ }" "${3//[$'\t\n']/ }" "${4//[$'\t\n']/ }" >> "$FIND"; }

default_base(){
  if [ -n "$BASE" ]; then echo "$BASE"; return; fi
  if git rev-parse --verify -q origin/main >/dev/null; then echo origin/main
  elif git rev-parse --verify -q HEAD~1 >/dev/null; then echo HEAD~1
  else echo ""; fi
}

# Gated doc files, NUL-delimited — a tracked doc path may contain spaces/globs; never
# word-split it (a skipped file would print a FALSE "clean"). Consumers: read -r -d ''.
doc_files_z(){ git ls-files -z | grep -zEi "$DOC_GLOB" | grep -zEv "$EXEMPT" || true; }

# Real top-level tracked dirs in THIS repo (override CODE_ROOTS in .evergreen.sh to pin).
top_roots(){ if [ -n "${CODE_ROOTS:-}" ]; then echo "$CODE_ROOTS"; else git ls-files | awk -F/ 'NF>1{print $1}' | sort -u | paste -sd'|' -; fi; }

# Signal 1: every file-like, in-repo path a doc names must exist on disk (or be tracked).
scan_path_existence(){
  local doc p roots; roots="$(top_roots)"; [ -n "$roots" ] || return 0
  while IFS= read -r -d '' doc; do
    grep -oE "($roots)/[A-Za-z0-9_./-]+" "$doc" 2>/dev/null | sort -u | while read -r p; do
      p="${p%%[).,\`\"]}"; case "$p" in */) p="${p%/}";; esac
      printf '%s' "$p" | grep -qiE "$EXT" || continue          # must look like a file
      [ -e "$p" ] && continue                                   # exists on disk
      git ls-files --error-unmatch "$p" >/dev/null 2>&1 && continue  # tracked
      emit in_docs_not_code high "$doc" "names \`$p\` which does not exist on disk"
    done
  done < <(doc_files_z)
}

# Signal 2: docs that still cite a path git renamed/deleted since BASE.
scan_renames(){
  local base="$1" status old new doc
  [ -n "$base" ] || return 0
  git diff --name-status --find-renames=50 "$base" HEAD 2>/dev/null | while IFS=$'\t' read -r status old new; do
    case "$status" in
      R*) while IFS= read -r -d '' doc; do grep -qF -- "$old" "$doc" 2>/dev/null && emit in_docs_not_code high "$doc" "cites \`$old\` which was renamed to \`$new\`"; done < <(doc_files_z);;
      D)  while IFS= read -r -d '' doc; do grep -qF -- "$old" "$doc" 2>/dev/null && emit in_docs_not_code high "$doc" "cites \`$old\` which was deleted"; done < <(doc_files_z);;
    esac
  done
}

# Signal 3: doc-documented CLI flags / env vars that no longer exist anywhere in code.
# Precision discipline (a noisy detector gets muted):
#  - only tokens inside `inline-code` spans count — prose UPPER_SNAKE (BOLD_TEXT) and
#    markdown rules/tables never reach the matcher; docs already backtick real flags/vars.
#  - flags are `--word` shaped; env/config tokens are UPPER_SNAKE *with* an underscore.
#  - existence is a WHOLE-TOKEN (boundary-aware) match against tracked NON-doc files, so
#    `--verbose` is NOT satisfied by `--verbose-mode` (that false-negative is the dangerous
#    direction for a zero-false-negative tool). A token living only in docs is drift.
# ponytail: O(tokens × files) grep; fine at repo scale, pre-filter if huge.
scan_contract(){
  local doc spans tok codelist
  codelist="$(mktemp)"; git ls-files -z 2>/dev/null | grep -zEiv "$DOC_GLOB" > "$codelist"
  [ -s "$codelist" ] || { rm -f "$codelist"; return 0; }
  in_code(){ [ -n "$(xargs -0 grep -lE -- "(^|[^A-Za-z0-9_-])$1([^A-Za-z0-9_-]|$)" < "$codelist" 2>/dev/null | head -1)" ]; }
  while IFS= read -r -d '' doc; do
    spans="$(grep -oE '`[^`]+`' "$doc" 2>/dev/null)"
    [ -n "$spans" ] || continue
    printf '%s\n' "$spans" | grep -oE -- '--[a-z][a-z0-9]+[a-z0-9-]*' | sort -u | while read -r tok; do
      [ -n "$tok" ] && { in_code "$tok" || emit in_docs_not_code high "$doc" "documents flag \`$tok\` not found in code"; }
    done
    printf '%s\n' "$spans" | grep -oE '\b[A-Z][A-Z0-9]*_[A-Z0-9_]+\b' | sort -u | while read -r tok; do
      [ -n "$tok" ] && { in_code "$tok" || emit in_docs_not_code medium "$doc" "documents env/config \`$tok\` not found in code"; }
    done
  done < <(doc_files_z)
  rm -f "$codelist"
}

# Signal 4 — RUNS CODE FROM THE DOC. OFF unless the operator passes --run-examples; the
# Stop hook NEVER passes it, so opening an untrusted repo can't auto-execute its README.
# Doc-author opt-in (a fence info string containing `evergreen`) is necessary but not
# sufficient — operator consent is required too. Execution gets a scrubbed env + scratch
# HOME/TMPDIR to shrink blast radius; this is NOT a sandbox (absolute paths/network still
# reach out). Only run --run-examples on docs you trust. A nonzero exit is drift.
scan_examples(){
  [ "$RUN_EXAMPLES" = 1 ] || return 0
  command -v bash >/dev/null 2>&1 || return 0
  local doc line trimmed inblk blk n rc tmp
  while IFS= read -r -d '' doc; do
    inblk=0; blk=""; n=0
    while IFS= read -r line; do
      trimmed="${line#"${line%%[![:space:]]*}"}"   # tolerate indented fences (CommonMark lists)
      case "$trimmed" in
        '```'*evergreen*) inblk=1; blk=""; n=$((n+1)); continue;;
        '```'*) [ "$inblk" = 1 ] || continue
                inblk=0; tmp="$(mktemp -d)"; rc=0
                ( cd "$tmp" && env -i HOME="$tmp" TMPDIR="$tmp" PATH="$PATH" bash -c "$blk" ) >/dev/null 2>&1 || rc=$?
                rm -rf "$tmp"
                [ "$rc" -ne 0 ] && emit in_docs_not_code high "$doc" "runnable example #$n exits nonzero ($rc)"
                continue;;
      esac
      [ "$inblk" = 1 ] && blk="$blk$line
"
    done < "$doc"
  done < <(doc_files_z)
}

# Signal 5: embed-from-source. A doc pins a fenced block to a source range with a marker
#   <!-- evergreen:embed path/to/src.rs:10-20 -->
#   ```rust
#   ...lines 10-20 of src.rs...
#   ```
# If the block no longer matches those source lines, it has drifted. `--fix` rewrites the
# block from source — a snippet that is regenerated can't silently lie.
embed_source(){ [ -f "$1" ] || return 1; awk -v s="$2" -v e="$3" 'NR>=s&&NR<=e' "$1"; }

# Parse one doc, comparing each embed block against its source range (mode=check) or
# rewriting it from source (mode=fix). Shared 3-state machine: 0 normal, 1 awaiting the
# opening fence, 2 inside the block body.
embed_one(){
  local doc="$1" mode="$2" line trimmed spec src rng start end want body exp tmp
  want=0; body=""; tmp="$(mktemp)"
  while IFS= read -r line; do
    trimmed="${line#"${line%%[![:space:]]*}"}"   # tolerate indented markers/fences (CommonMark lists)
    case $want in
      0) [ "$mode" = fix ] && printf '%s\n' "$line" >> "$tmp"
         case "$line" in *'evergreen:embed'*)
            spec="$(printf '%s' "$line" | sed -E 's/.*evergreen:embed +([^ ]+).*/\1/')"
            src="${spec%%:*}"; rng="${spec#*:}"; start="${rng%%-*}"; end="${rng#*-}"
            [ "$end" = "$rng" ] && end="$start"
            case "$start$end" in ''|*[!0-9]*) want=0;; *) want=1;; esac;;
         esac;;
      1) [ "$mode" = fix ] && printf '%s\n' "$line" >> "$tmp"
         case "$trimmed" in '```'*) want=2; body="";; '') ;; *) want=0;; esac;;
      2) case "$trimmed" in
           '```'*)
             if exp="$(embed_source "$src" "$start" "$end")"; then
               if printf '%s\n' "$exp" | grep -q '^[[:space:]]*```'; then
                 # the source range itself contains a fence line; writing it would break the
                 # markdown block and never converge — refuse, leave the body untouched.
                 [ "$mode" = check ] && emit in_docs_not_code high "$doc" "embed source \`$src:$start-$end\` contains a code fence — cannot embed safely (narrow the range)"
                 [ "$mode" = fix ] && printf '%s' "$body" >> "$tmp"
               else
                 [ "$mode" = check ] && { [ "${body%$'\n'}" != "$exp" ] && emit in_docs_not_code high "$doc" "embedded snippet from \`$src:$start-$end\` has drifted from source"; }
                 [ "$mode" = fix ] && printf '%s\n' "$exp" >> "$tmp"
               fi
             else
               [ "$mode" = check ] && emit in_docs_not_code high "$doc" "embed source \`$src\` missing or range $start-$end invalid"
               [ "$mode" = fix ] && printf '%s' "$body" >> "$tmp"
             fi
             [ "$mode" = fix ] && printf '%s\n' "$line" >> "$tmp"
             want=0;;
           *) body="$body$line
"; [ "$mode" = fix ] || : ;;
         esac;;
    esac
  done < "$doc"
  if [ "$mode" = fix ] && ! cmp -s "$tmp" "$doc"; then cp "$tmp" "$doc"; echo "fixed (embed): $doc" >&2; fi
  rm -f "$tmp"
}

scan_embed(){ while IFS= read -r -d '' doc; do embed_one "$doc" check; done < <(doc_files_z); }

# Signal 6: SHA-pinned source→doc manifest. `.evergreen-manifest` is TSV lines
#   doc<TAB>source<TAB>blob-sha               (whole-file pin)
#   doc<TAB>source<TAB>Lstart-Lend<TAB>sha    (line-range pin — method-level)
# (# comments / blank lines ignored). The sha is captured when the doc was last verified
# against that source: `git hash-object source` for the whole file, or the hash of just
# the pinned lines. A range pin is the deterministic stand-in for an AST-hash — unrelated
# edits elsewhere in the file don't trip it. Content hashing differently flags the doc for
# re-verification (not proven wrong — the source moved under it). `--fix` re-pins.
MANIFEST=".evergreen-manifest"
# pin_hash SRC RANGE: hash the whole file (empty RANGE) or just lines start-end.
pin_hash(){
  if [ -z "$2" ]; then git hash-object "$1" 2>/dev/null
  else awk -v s="${2%-*}" -v e="${2#*-}" 'NR>=s&&NR<=e' "$1" 2>/dev/null | git hash-object --stdin 2>/dev/null; fi
}
scan_manifest(){
  [ -f "$MANIFEST" ] || return 0
  local doc src f3 f4 range sha cur where
  while IFS=$'\t' read -r doc src f3 f4 || [ -n "${doc:-}" ]; do
    case "$doc" in ''|'#'*) continue;; esac
    if [ -n "$f4" ]; then range="$f3"; sha="${f4%$'\r'}"; where="$src:$range"
    else range=""; sha="${f3%$'\r'}"; where="$src"; fi   # tolerate CRLF on the last field
    [ -n "$src" ] && [ -n "$sha" ] || continue
    case "$range" in *[!0-9-]*|*-*-*) emit needs_reverify medium "$doc" "manifest range \`$range\` for \`$src\` is malformed"; continue;; esac
    if [ ! -f "$src" ]; then emit in_docs_not_code high "$doc" "manifest source \`$src\` no longer exists"; continue; fi
    cur="$(pin_hash "$src" "$range")"; [ -n "$cur" ] || continue
    [ "$cur" = "$sha" ] || emit needs_reverify medium "$doc" "source \`$where\` changed since verified (pinned ${sha:0:8}…, now ${cur:0:8}…) — re-verify"
  done < "$MANIFEST"
}
fix_manifest(){
  [ -f "$MANIFEST" ] || return 0
  local tmp line doc src f3 f4 range cur; tmp="$(mktemp)"
  while IFS= read -r line || [ -n "$line" ]; do
    case "$line" in ''|'#'*) printf '%s\n' "$line" >> "$tmp"; continue;; esac
    IFS=$'\t' read -r doc src f3 f4 <<EOF
$line
EOF
    [ -n "$f4" ] && range="$f3" || range=""
    if [ -n "$src" ] && [ -f "$src" ] && cur="$(pin_hash "$src" "$range")" && [ -n "$cur" ]; then
      if [ -n "$range" ]; then printf '%s\t%s\t%s\t%s\n' "$doc" "$src" "$range" "$cur" >> "$tmp"
      else printf '%s\t%s\t%s\n' "$doc" "$src" "$cur" >> "$tmp"; fi
    else printf '%s\n' "$line" >> "$tmp"; fi
  done < "$MANIFEST"
  if ! cmp -s "$tmp" "$MANIFEST"; then cp "$tmp" "$MANIFEST"; echo "fixed (manifest re-pin): $MANIFEST" >&2; fi
  rm -f "$tmp"
}

# --fix applies ONLY derivable fixes (embed refresh from source; manifest re-pin). It
# never rewrites prose — that stays a human/model job. Fix messages go to stderr so
# --json/--sarif stdout stays clean.
do_fix(){
  local doc
  while IFS= read -r -d '' doc; do embed_one "$doc" fix; done < <(doc_files_z)
  fix_manifest
}

# --fix-prose: the model half of "keep fresh", drawn safely. For docs the deterministic
# pass flagged with a DEAD PATH reference, ask the model to draft a MINIMAL correction.
# Two DETERMINISTIC gates then guarantee, without trusting the model: (1) the draft no
# longer contains the dead path, and (2) it adds no net lines (no injected preamble). A
# third independent model review-call backs these up against rewording — but that part is
# best-effort, so applied edits go to the WORKING TREE and the diff is printed for you to
# review with `git diff`; nothing is committed. Anything that fails a gate (after 3 tries)
# is left as needs_review. Opt-in; requires the `claude` CLI.
prose_fix_one(){
  local doc="$1" deadpaths="$2" orig fixed verdict p attempt clean
  orig="$(cat "$doc")"
  # Up to 3 attempts: the gates below guarantee SAFETY on every try (a bad draft is never
  # applied); retries just recover EFFICACY from model variance (e.g. an added preamble).
  for attempt in 1 2 3; do
    [ "$attempt" -gt 1 ] && echo "prose-fix: retry $attempt for $doc" >&2
    fixed="$(claude -p "You fix documentation drift. The file below names file path(s) that NO LONGER EXIST in the repo. Output the ENTIRE file with ONLY the dead path reference(s) minimally corrected or removed and EVERYTHING else byte-identical. Your output's first character MUST be the file's first character — no preamble, no 'Here is', no explanation, no code fences, and do NOT restate the dead path anywhere.

$orig" 2>/dev/null)"
    [ -n "$fixed" ] && [ "$fixed" != "$orig" ] || continue
    # Deterministic gate (LLM-independent): the draft must actually REMOVE every dead path.
    # Catches the model re-mentioning the path (e.g. in a preamble) — that draft is refused.
    clean=1; for p in $deadpaths; do printf '%s' "$fixed" | grep -qF -- "$p" && { clean=0; break; }; done
    [ "$clean" = 1 ] || continue
    # Deterministic gate 2: a dead-path correction edits/removes lines, it never ADDS them.
    # Rejecting net-new lines kills injected preambles/commentary without trusting the model.
    [ "$(printf '%s\n' "$fixed" | wc -l)" -le "$(printf '%s\n' "$orig" | wc -l)" ] || continue
    # Review gate: an independent model call backs up the deterministic gates on rewording.
    verdict="$(claude -p "Reply with exactly one word, PASS or FAIL. PASS only if PROPOSED differs from ORIGINAL solely by correcting or removing dead file-path references — no other prose changed, nothing added, no new sentences/claims. Else FAIL.

ORIGINAL:
$orig

PROPOSED:
$fixed" 2>/dev/null | grep -oiE 'PASS|FAIL' | head -1 | tr '[:lower:]' '[:upper:]')"
    [ "$verdict" = PASS ] || continue
    printf '%s\n' "$fixed" > "$doc"
    { echo "prose-fix applied + validated (review with git diff): $doc"; diff -u <(printf '%s\n' "$orig") <(printf '%s\n' "$fixed") | sed 's/^/  /'; } >&2
    return 0
  done
  echo "prose-fix: no validated fix for $doc after 3 attempts — left as needs_review (no edit)" >&2
}
prose_fix(){
  command -v claude >/dev/null 2>&1 || { echo "evergreen: --fix-prose needs the \`claude\` CLI" >&2; return 1; }
  local doc deadpaths
  awk -F'\t' '$1=="in_docs_not_code" && $4 ~ /does not exist on disk/ {print $3}' "$FIND" | sort -u | while read -r doc; do
    [ -f "$doc" ] || continue
    deadpaths="$(awk -F'\t' -v d="$doc" '$3==d && $4 ~ /does not exist on disk/ {p=$4; sub(/.*names `/,"",p); sub(/`.*/,"",p); print p}' "$FIND")"
    prose_fix_one "$doc" "$deadpaths"
  done
}

# ---- coverage (completeness, a different axis from drift) --------------------
# Doc-comment coverage of PUBLIC symbols. Parser-backed where a parser is available,
# graceful regex fallback otherwise:
#   python : python3 stdlib `ast` (exact) — else regex
#   js/ts  : `deno doc --json` (exact, real parser) — else regex
#   go/rust: regex heuristic (no zero-install parser here; tree-sitter is the upgrade path)
# Regex heuristic (fallback / go / rust):
#   python: `def`/`async def`/`class` at any indent (non-_), followed by a """ docstring
#   js/ts:  `export function|class|const`, preceded by // or */ comment (top-level only)
#   go:     exported `func`/`type` (Capitalized), preceded by // comment (methods incl.)
#   rust:   `pub fn|struct|enum|trait` at any indent, preceded by /// //! or */ (impl methods incl.)
coverage_file(){
  awk -v lang="$2" '
    function prev_is_doc(p){
      if(lang=="go")   return p ~ /^[[:space:]]*\/\//
      if(lang=="rust") return (p ~ /^[[:space:]]*\/\/\//)||(p ~ /^[[:space:]]*\/\/!/)||(p ~ /\*\/[[:space:]]*$/)
      if(lang=="js")   return (p ~ /^[[:space:]]*\/\//)||(p ~ /\*\/[[:space:]]*$/)
      return 0
    }
    {
      sym=0
      if(lang=="python"){ if(($0 ~ /^[[:space:]]*((async[[:space:]]+)?def|class)[[:space:]]+[A-Za-z]/)) sym=1 }
      else if(lang=="go"){ if(($0 ~ /^func[[:space:]]+[A-Z]/)||($0 ~ /^func[[:space:]]*\([^)]*\)[[:space:]]*[A-Z]/)||($0 ~ /^type[[:space:]]+[A-Z]/)) sym=1 }
      else if(lang=="rust"){ if($0 ~ /^[[:space:]]*pub[[:space:]]+(fn|struct|enum|trait)[[:space:]]+[A-Za-z]/) sym=1 }
      else if(lang=="js"){ if(($0 ~ /^export[[:space:]]+(default[[:space:]]+)?(async[[:space:]]+)?(function|class)[[:space:]]+[A-Za-z]/)||($0 ~ /^export[[:space:]]+const[[:space:]]+[A-Za-z_]/)) sym=1 }
      if(sym){ total++; if(lang=="python") pend=1; else if(prev_is_doc(prevnb)) doc++ }
      else if(pend){ if($0 ~ /^[[:space:]]*$/){} else { if($0 ~ /^[[:space:]]*"""/) doc++; pend=0 } }
      if($0 !~ /^[[:space:]]*$/) prevnb=$0
    }
    END{ print (doc+0), (total+0) }
  ' "$1"
}
# Exact Python coverage via the stdlib `ast` parser (no regex guesswork): every
# Function/AsyncFunction/ClassDef whose name isn't `_`-prefixed, with ast.get_docstring.
# Accepts many files; silently skips any that don't parse (the rest still count).
coverage_py_ast(){
  python3 - "$@" <<'PY' 2>/dev/null
import ast,sys
doc=tot=0
for fn in sys.argv[1:]:
    try: tree=ast.parse(open(fn,encoding="utf-8",errors="replace").read())
    except Exception: continue
    for n in ast.walk(tree):
        if isinstance(n,(ast.FunctionDef,ast.AsyncFunctionDef,ast.ClassDef)) and not n.name.startswith("_"):
            tot+=1
            if ast.get_docstring(n): doc+=1
print(doc,tot)
PY
}
# Exact JS/TS coverage via `deno doc --json` (a real parser): exported function/class/
# interface/enum/type/variable + public class methods; jsDoc present = documented. Needs
# deno + python3 (to read deno's JSON); caller falls back to regex if either is missing/errs.
coverage_js_deno(){
  local out; out="$(deno doc --json "$@" 2>/dev/null)" || return 1
  [ -n "$out" ] || return 1
  printf '%s' "$out" | python3 -c '
import sys,json
try: d=json.load(sys.stdin)
except Exception: sys.exit(1)
doc=tot=0
for f,info in d.get("nodes",{}).items():
 for sym in info.get("symbols",[]):
  for decl in sym.get("declarations",[]):
   if decl.get("declarationKind")!="export": continue
   if decl.get("kind") not in ("function","class","interface","variable","enum","typeAlias","namespace"): continue
   tot+=1
   if decl.get("jsDoc"): doc+=1
   if decl.get("kind")=="class":
    for m in (decl.get("def",{}).get("methods") or []):
     if m.get("name","").startswith("_"): continue
     tot+=1
     if m.get("jsDoc"): doc+=1
print(doc,tot)'
}
# Accumulate a "doc total" pair into run_coverage's doc/tot (bash dynamic scope).
cov_add(){ local d t; d="${1%% *}"; t="${1##* }"; case "$d$t" in ''|*[!0-9]*) return;; esac; doc=$((doc+d)); tot=$((tot+t)); }
run_coverage(){
  local f r doc=0 tot=0 pct base pylabel=regex jslabel=regex
  local -a pyf=() jsf=() gof=() rsf=()
  while IFS= read -r -d '' f; do
    case "$f" in
      *.py) pyf+=("$f");;
      *.ts|*.tsx|*.js|*.jsx|*.mjs|*.cjs) jsf+=("$f");;
      *.go) gof+=("$f");;
      *.rs) rsf+=("$f");;
    esac
  done < <(git ls-files -z)
  if [ "${#pyf[@]}" -gt 0 ]; then
    if command -v python3 >/dev/null 2>&1 && r="$(coverage_py_ast "${pyf[@]}")" && [ -n "$r" ]; then pylabel=ast
    else r="$(for f in "${pyf[@]}"; do coverage_file "$f" python; done | awk '{d+=$1;t+=$2}END{print d,t}')"; fi
    cov_add "$r"
  fi
  if [ "${#jsf[@]}" -gt 0 ]; then
    if command -v deno >/dev/null 2>&1 && command -v python3 >/dev/null 2>&1 && r="$(coverage_js_deno "${jsf[@]}")" && [ -n "$r" ]; then jslabel=deno
    else r="$(for f in "${jsf[@]}"; do coverage_file "$f" js; done | awk '{d+=$1;t+=$2}END{print d,t}')"; fi
    cov_add "$r"
  fi
  [ "${#gof[@]}" -gt 0 ] && for f in "${gof[@]}"; do cov_add "$(coverage_file "$f" go)"; done
  [ "${#rsf[@]}" -gt 0 ] && for f in "${rsf[@]}"; do cov_add "$(coverage_file "$f" rust)"; done
  if [ "$tot" -eq 0 ]; then pct=100; else pct=$(( doc * 100 / tot )); fi
  base=""; [ -f .evergreen-coverage ] && base="$(tr -dc 0-9 < .evergreen-coverage)"
  if [ "$FIX" -eq 1 ]; then echo "$pct" > .evergreen-coverage; echo "coverage baseline set: ${pct}%" >&2; fi
  [ "$BADGE" -eq 1 ] && badge_inject "$pct"
  if [ "$MODE" = json ]; then
    printf '{"coverage_pct":%s,"documented":%s,"total":%s,"fail_under":%s,"baseline":%s}\n' "$pct" "$doc" "$tot" "$FAIL_UNDER" "${base:-null}"
  else
    printf 'evergreen coverage: %s%% (%s/%s public symbols documented) [py: %s; js/ts: %s; go/rs: regex]\n' "$pct" "$doc" "$tot" "$pylabel" "$jslabel"
    [ -n "$base" ] && printf '  baseline: %s%%\n' "$base"
  fi
  if [ "$CI" -eq 1 ]; then
    if [ "$pct" -lt "$FAIL_UNDER" ]; then echo "coverage ${pct}% < fail-under ${FAIL_UNDER}%" >&2; return 2; fi
    if [ -n "$base" ] && [ "$pct" -lt "$base" ]; then echo "coverage dropped: ${pct}% < baseline ${base}% (ratchet)" >&2; return 2; fi
  fi
  return 0
}

# --badge: write/refresh a shields.io coverage badge between marker comments in README.md
#   <!-- evergreen:badge:start --> ... <!-- evergreen:badge:end -->
# Idempotent; if the markers are absent, the badge markdown is printed to stderr (so it
# never corrupts --json/--sarif stdout) with a hint to add them.
badge_inject(){
  local pct="$1" color md tmp f="README.md"
  if [ "$pct" -ge 80 ]; then color=brightgreen; elif [ "$pct" -ge 50 ]; then color=yellow; else color=red; fi
  md="![docs coverage](https://img.shields.io/badge/docs_coverage-${pct}%25-${color})"
  if [ -f "$f" ] && grep -q 'evergreen:badge:start' "$f"; then
    tmp="$(mktemp)"
    # Buffer the whole file and replace only the lines strictly between the FIRST start
    # marker and the FIRST end marker after it. If there is no such pair (missing/typo'd
    # end, or end-before-start), leave the file byte-for-byte UNCHANGED — never drop content.
    awk -v md="$md" '
      {lines[NR]=$0} /evergreen:badge:start/{if(!s)s=NR}
      END{
        e=0; for(i=s+1;i<=NR;i++) if(lines[i] ~ /evergreen:badge:end/){e=i; break}
        if(s && e){ for(i=1;i<=NR;i++){ if(i==s){print lines[i]; print md; continue} if(i>s && i<e) continue; print lines[i] } }
        else      { for(i=1;i<=NR;i++) print lines[i] }
      }' "$f" > "$tmp"
    if ! cmp -s "$tmp" "$f"; then cp "$tmp" "$f"; echo "updated coverage badge in $f (${pct}%)" >&2
    elif ! grep -q 'evergreen:badge:end' "$f"; then echo "badge: 'badge:start' present but no 'badge:end' in $f — left untouched" >&2; fi
    rm -f "$tmp"
  else
    { printf '%s\n' "$md"; echo "(add <!-- evergreen:badge:start --> / <!-- evergreen:badge:end --> to README.md to inject)"; } >&2
  fi
}

run_scan(){
  local base; base="$(default_base)"
  scan_path_existence
  scan_renames "$base"
  scan_contract
  scan_embed
  scan_manifest
  scan_examples
}

# freshness_pct: 100 minus a severity-weighted penalty (high 15, med 5, low 2), floored at 0.
# Deterministic and monotonic — more/worse drift can only lower it. Empty findings -> 100.
compute_score(){ awk -F'\t' '{if($2=="high")h++;else if($2=="medium")m++;else l++} END{s=100-(h*15+m*5+l*2); if(s<0)s=0; print s}' "$FIND"; }

# Append each finding as one JSON object to the --log file: a cross-session audit trail.
log_jsonl(){
  [ -n "$LOGFILE" ] || return 0
  local ts; ts="$(date -u +%FT%TZ 2>/dev/null || echo "")"
  awk -F'\t' -v ts="$ts" 'function j(s){gsub(/\\/,"\\\\",s);gsub(/"/,"\\\"",s);return s}
    {printf "{\"ts\":\"%s\",\"category\":\"%s\",\"severity\":\"%s\",\"file\":\"%s\",\"detail\":\"%s\"}\n", ts, j($1), j($2), j($3), j($4)}' "$FIND" >> "$LOGFILE"
}

render_sarif(){
  printf '{"version":"2.1.0","$schema":"https://json.schemastore.org/sarif-2.1.0.json","runs":[{"tool":{"driver":{"name":"evergreen","informationUri":"https://github.com/","rules":[]}},"results":['
  awk -F'\t' 'function j(s){gsub(/\\/,"\\\\",s);gsub(/"/,"\\\"",s);return s}
    {lvl=($2=="high")?"error":(($2=="medium")?"warning":"note");
     printf "%s{\"ruleId\":\"%s\",\"level\":\"%s\",\"message\":{\"text\":\"%s\"},\"locations\":[{\"physicalLocation\":{\"artifactLocation\":{\"uri\":\"%s\"}}}]}", (NR>1?",":""), j($1), lvl, j($4), j($3)}' "$FIND"
  printf ']}]}\n'
}

render(){
  log_jsonl
  local total pct; total=$(wc -l < "$FIND" | tr -d ' '); pct="$(compute_score)"
  case "$MODE" in
    json)
      printf '{"findings":['
      awk -F'\t' 'function j(s){gsub(/\\/,"\\\\",s);gsub(/"/,"\\\"",s);return s}
        NR>1{printf ","} {printf "{\"category\":\"%s\",\"severity\":\"%s\",\"file\":\"%s\",\"detail\":\"%s\"}", j($1),j($2),j($3),j($4)}' "$FIND"
      printf '],"count":%s,"freshness_pct":%s}\n' "$total" "$pct"
      ;;
    sarif) render_sarif ;;
    *)
      if [ "$total" -eq 0 ]; then echo "✓ evergreen: no drift detected"; else
        echo "evergreen: $total finding(s)"
        sort -t$'\t' -k1,1 "$FIND" | while IFS=$'\t' read -r c s f d; do
          printf "  [%s] %-18s %s — %s\n" "$s" "$c" "$f" "$d"
        done
      fi
      [ "$SCORE" -eq 1 ] && echo "freshness: ${pct}% (100 = no drift)"
      ;;
  esac
  # exit code for --ci
  if [ "$CI" -eq 1 ]; then
    local need worst; need=$(sev_rank "$FAIL_LEVEL"); worst=0
    while IFS=$'\t' read -r c s f d; do [ "$(sev_rank "$s")" -ge "$need" ] && worst=1; done < "$FIND"
    if [ "$worst" -eq 1 ]; then exit 2; fi
  fi
}

# ---- self-test: build a throwaway repo with known drift, assert detection ----
selftest(){
  local t; t="$(mktemp -d)"; ( cd "$t" || exit 1
    git init -q; git config user.email t@t; git config user.name t
    mkdir -p src docs
    {                                                  # code contains these whole tokens:
      printf 'let x = "--real-flag"\n'                  #   --real-flag (must NOT flag)
      printf '// also --verbose-mode here\n'            #   --verbose-mode (so --verbose must NOT substring-match)
      printf 'REAL_VAR=1\n'                             #   REAL_VAR (must NOT flag)
      printf 'API_KEY_SECRET=2\n'                       #   API_KEY_SECRET (so API_KEY must NOT substring-match)
    } > src/keep.swift
    {
      printf '# Doc\n'
      printf 'See `src/keep.swift` and `src/GONE.swift`.\n'      # rung 1: GONE.swift missing
      printf 'Run with `--real-flag` or `--ghost-flag`.\n'        # rung 3: --ghost-flag absent
      printf 'Also `--verbose` (only --verbose-mode exists).\n'   # rung 3: boundary -> --verbose IS drift
      printf 'Set `REAL_VAR` but not `GHOST_VAR` or `API_KEY`.\n' # rung 3: GHOST_VAR + API_KEY are drift
      printf 'Prose MAX_SIZE and BOLD_TEXT are not code.\n'       # no backticks -> must NOT flag
      printf '\n```bash evergreen\nexit 7\n```\n'                 # rung 4: opt-in block fails
    } > docs/guide.md
    git add -A; git commit -qm init
    git mv src/keep.swift src/renamed.swift; git commit -qm rename
  )
  local out; out="$(cd "$t" && bash "$SELF" --base HEAD~1 --run-examples 2>/dev/null || true)"
  rm -rf "$t"
  echo "$out" | grep -q "GONE.swift"     || { echo "FAIL: missing path-existence drift"; echo "$out"; exit 1; }
  echo "$out" | grep -q "renamed"        || { echo "FAIL: missing rename drift"; echo "$out"; exit 1; }
  echo "$out" | grep -q -- "--ghost-flag" || { echo "FAIL: missing flag-contract drift"; echo "$out"; exit 1; }
  echo "$out" | grep -q -- "--verbose\`"  || { echo "FAIL: boundary false-negative (--verbose vs --verbose-mode)"; echo "$out"; exit 1; }
  echo "$out" | grep -q "GHOST_VAR"      || { echo "FAIL: missing env-contract drift"; echo "$out"; exit 1; }
  echo "$out" | grep -q "API_KEY\`"      || { echo "FAIL: boundary false-negative (API_KEY vs API_KEY_SECRET)"; echo "$out"; exit 1; }
  echo "$out" | grep -q "example #1"     || { echo "FAIL: missing runnable-example drift"; echo "$out"; exit 1; }
  echo "$out" | grep -q -- "--real-flag" && { echo "FAIL: false positive on --real-flag"; echo "$out"; exit 1; }
  echo "$out" | grep -q "REAL_VAR"       && { echo "FAIL: false positive on REAL_VAR"; echo "$out"; exit 1; }
  echo "$out" | grep -qE "MAX_SIZE|BOLD_TEXT" && { echo "FAIL: false positive on prose (non-backticked) token"; echo "$out"; exit 1; }
  echo "✓ selftest passed (path + rename + boundary-contract + opt-in example, no prose/substring false positives)"
}

SELF="$(cd "$(dirname "$0")" && pwd)/$(basename "$0")"
if [ "${RUN_SELFTEST:-0}" = 1 ]; then selftest; exit 0; fi
# Never report "clean" when we could not actually run: a false green is worse than a miss.
git rev-parse --is-inside-work-tree >/dev/null 2>&1 || { echo "evergreen: not a git repository — cannot scan (run inside a repo)" >&2; exit 1; }
if [ "$COVERAGE" -eq 1 ]; then run_coverage; exit $?; fi
[ "$FIX" -eq 1 ] && do_fix
run_scan
if [ "$FIX_PROSE" -eq 1 ]; then prose_fix; : > "$FIND"; run_scan; fi   # re-scan to reflect applied fixes
render
exit 0
