{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "documentation": {
      "additionalProperties": false,
      "properties": {
        "sha256": {"pattern": "^[0-9a-f]{64}$", "type": "string"},
        "template": {"minLength": 1, "type": "string"}
      },
      "required": ["template", "sha256"],
      "type": "object"
    },
    "group_id": {"pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$", "type": "string"},
    "harness": {
      "additionalProperties": false,
      "properties": {
        "argv": {
          "items": false,
          "maxItems": 3,
          "minItems": 3,
          "prefixItems": [
            {
              "enum": [
                "/opt/evergreen/bin/python-oracle-v1",
                "/opt/evergreen/bin/java-oracle-v1",
                "/opt/evergreen/bin/typescript-oracle-v1",
                "/opt/evergreen/bin/rust-oracle-v1",
                "/opt/evergreen/bin/go-oracle-v1"
              ]
            },
            {
              "pattern": "^/input/[A-Za-z0-9_-]+(?:\\.[A-Za-z0-9_-]+)*(?:/[A-Za-z0-9_-]+(?:\\.[A-Za-z0-9_-]+)*)*$",
              "type": "string"
            },
            {"const": "/control/oracle-v1.json"}
          ],
          "type": "array"
        }
      },
      "required": ["argv"],
      "type": "object"
    },
    "kind": {"const": "evergreen-executable-documentation-oracle"},
    "language": {"enum": ["python", "java", "typescript", "rust", "go"]},
    "mutation": {
      "additionalProperties": false,
      "properties": {
        "derivative_sha256": {"pattern": "^[0-9a-f]{64}$", "type": "string"},
        "operator": {
          "enum": [
            "return-value-1-to-2-v1",
            "raises-none-to-value-error-v1",
            "default-value-one-to-two-v1",
            "cardinality-one-to-two-v1",
            "state-change-before-to-after-v1"
          ]
        },
        "offset": {"minimum": 0, "type": "integer"}
      },
      "required": ["operator", "offset", "derivative_sha256"],
      "type": "object"
    },
    "oracle": {
      "additionalProperties": false,
      "properties": {
        "expected_observable": {
          "additionalProperties": false,
          "properties": {
            "exit_code": {"const": 0},
            "stdout": {"maxLength": 4096, "minLength": 1, "type": "string"}
          },
          "required": ["exit_code", "stdout"],
          "type": "object"
        },
        "kind": {
          "enum": ["return-value", "raises", "default-value", "cardinality", "state-change"]
        }
      },
      "required": ["kind", "expected_observable"],
      "type": "object"
    },
    "project": {"pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$", "type": "string"},
    "sandbox": {
      "additionalProperties": false,
      "properties": {
        "engine": {"const": "docker"},
        "image": {
          "pattern": "^[a-z0-9][a-z0-9._/-]*@sha256:[0-9a-f]{64}$",
          "type": "string"
        },
        "profile": {"const": "evergreen-oracle-v1"}
      },
      "required": ["engine", "image", "profile"],
      "type": "object"
    },
    "schema_version": {"const": 1},
    "seed_sha256": {"pattern": "^[0-9a-f]{64}$", "type": "string"},
    "semantic_noop": {
      "additionalProperties": false,
      "properties": {
        "derivative_sha256": {"pattern": "^[0-9a-f]{64}$", "type": "string"},
        "id": {"const": "comment-v1"}
      },
      "required": ["id", "derivative_sha256"],
      "type": "object"
    },
    "source": {
      "additionalProperties": false,
      "properties": {
        "code": {"minLength": 1, "type": "string"},
        "commit": {"pattern": "^(?:[0-9a-f]{40}|[0-9a-f]{64})$", "type": "string"},
        "license": {"minLength": 1, "type": "string"},
        "origin": {"pattern": "^https://", "type": "string"},
        "path": {
          "pattern": "^[A-Za-z0-9_-]+(?:\\.[A-Za-z0-9_-]+)*(?:/[A-Za-z0-9_-]+(?:\\.[A-Za-z0-9_-]+)*)*$",
          "type": "string"
        },
        "sha256": {"pattern": "^[0-9a-f]{64}$", "type": "string"}
      },
      "required": ["origin", "commit", "license", "path", "code", "sha256"],
      "type": "object"
    }
  },
  "required": [
    "schema_version",
    "kind",
    "group_id",
    "project",
    "source",
    "language",
    "documentation",
    "harness",
    "oracle",
    "mutation",
    "semantic_noop",
    "sandbox",
    "seed_sha256"
  ],
  "allOf": [
    {
      "if": {"properties": {"language": {"const": "python"}}, "required": ["language"]},
      "then": {
        "properties": {
          "harness": {
            "properties": {
              "argv": {"prefixItems": [{"const": "/opt/evergreen/bin/python-oracle-v1"}]}
            }
          }
        }
      }
    },
    {
      "if": {"properties": {"language": {"const": "java"}}, "required": ["language"]},
      "then": {
        "properties": {
          "harness": {
            "properties": {
              "argv": {"prefixItems": [{"const": "/opt/evergreen/bin/java-oracle-v1"}]}
            }
          }
        }
      }
    },
    {
      "if": {"properties": {"language": {"const": "typescript"}}, "required": ["language"]},
      "then": {
        "properties": {
          "harness": {
            "properties": {
              "argv": {
                "prefixItems": [{"const": "/opt/evergreen/bin/typescript-oracle-v1"}]
              }
            }
          }
        }
      }
    },
    {
      "if": {"properties": {"language": {"const": "rust"}}, "required": ["language"]},
      "then": {
        "properties": {
          "harness": {
            "properties": {
              "argv": {"prefixItems": [{"const": "/opt/evergreen/bin/rust-oracle-v1"}]}
            }
          }
        }
      }
    },
    {
      "if": {"properties": {"language": {"const": "go"}}, "required": ["language"]},
      "then": {
        "properties": {
          "harness": {
            "properties": {
              "argv": {"prefixItems": [{"const": "/opt/evergreen/bin/go-oracle-v1"}]}
            }
          }
        }
      }
    },
    {
      "if": {"properties": {"mutation": {"properties": {"operator": {"const": "return-value-1-to-2-v1"}}, "required": ["operator"]}}, "required": ["mutation"]},
      "then": {"properties": {
        "oracle": {"properties": {"kind": {"const": "return-value"}, "expected_observable": {"const": {"exit_code": 0, "stdout": "1\n"}}}}
      }}
    },
    {
      "if": {"properties": {"mutation": {"properties": {"operator": {"const": "raises-none-to-value-error-v1"}}, "required": ["operator"]}}, "required": ["mutation"]},
      "then": {"properties": {
        "oracle": {"properties": {"kind": {"const": "raises"}, "expected_observable": {"const": {"exit_code": 0, "stdout": "no-error\n"}}}}
      }}
    },
    {
      "if": {"properties": {"mutation": {"properties": {"operator": {"const": "default-value-one-to-two-v1"}}, "required": ["operator"]}}, "required": ["mutation"]},
      "then": {"properties": {
        "oracle": {"properties": {"kind": {"const": "default-value"}, "expected_observable": {"const": {"exit_code": 0, "stdout": "default:1\n"}}}}
      }}
    },
    {
      "if": {"properties": {"mutation": {"properties": {"operator": {"const": "cardinality-one-to-two-v1"}}, "required": ["operator"]}}, "required": ["mutation"]},
      "then": {"properties": {
        "oracle": {"properties": {"kind": {"const": "cardinality"}, "expected_observable": {"const": {"exit_code": 0, "stdout": "cardinality:1\n"}}}}
      }}
    },
    {
      "if": {"properties": {"mutation": {"properties": {"operator": {"const": "state-change-before-to-after-v1"}}, "required": ["operator"]}}, "required": ["mutation"]},
      "then": {"properties": {
        "oracle": {"properties": {"kind": {"const": "state-change"}, "expected_observable": {"const": {"exit_code": 0, "stdout": "state:changed\n"}}}}
      }}
    },
    {"if":{"properties":{"language":{"const":"python"},"mutation":{"properties":{"operator":{"const":"return-value-1-to-2-v1"}},"required":["operator"]}},"required":["language","mutation"]},"then":{"properties":{"source":{"properties":{"code":{"pattern":"def\\s+value\\s*\\(\\s*\\)\\s*:\\s*return 1"}}}}}},
    {"if":{"properties":{"language":{"const":"java"},"mutation":{"properties":{"operator":{"const":"return-value-1-to-2-v1"}},"required":["operator"]}},"required":["language","mutation"]},"then":{"properties":{"source":{"properties":{"code":{"pattern":"static\\s+int\\s+value\\s*\\(\\s*\\)\\s*\\{\\s*return 1"}}}}}},
    {"if":{"properties":{"language":{"const":"typescript"},"mutation":{"properties":{"operator":{"const":"return-value-1-to-2-v1"}},"required":["operator"]}},"required":["language","mutation"]},"then":{"properties":{"source":{"properties":{"code":{"pattern":"function\\s+value\\s*\\(\\s*\\)\\s*\\{\\s*return 1"}}}}}},
    {"if":{"properties":{"language":{"const":"rust"},"mutation":{"properties":{"operator":{"const":"return-value-1-to-2-v1"}},"required":["operator"]}},"required":["language","mutation"]},"then":{"properties":{"source":{"properties":{"code":{"pattern":"fn\\s+value\\s*\\(\\s*\\)\\s*->\\s*i32\\s*\\{\\s*return 1"}}}}}},
    {"if":{"properties":{"language":{"const":"go"},"mutation":{"properties":{"operator":{"const":"return-value-1-to-2-v1"}},"required":["operator"]}},"required":["language","mutation"]},"then":{"properties":{"source":{"properties":{"code":{"pattern":"func\\s+value\\s*\\(\\s*\\)\\s*int\\s*\\{\\s*return 1"}}}}}},
    {"if":{"properties":{"language":{"const":"python"},"mutation":{"properties":{"operator":{"const":"raises-none-to-value-error-v1"}},"required":["operator"]}},"required":["language","mutation"]},"then":{"properties":{"source":{"properties":{"code":{"pattern":"if False"}}}}}},
    {"if":{"properties":{"language":{"const":"java"},"mutation":{"properties":{"operator":{"const":"raises-none-to-value-error-v1"}},"required":["operator"]}},"required":["language","mutation"]},"then":{"properties":{"source":{"properties":{"code":{"pattern":"if \\(false\\)"}}}}}},
    {"if":{"properties":{"language":{"const":"typescript"},"mutation":{"properties":{"operator":{"const":"raises-none-to-value-error-v1"}},"required":["operator"]}},"required":["language","mutation"]},"then":{"properties":{"source":{"properties":{"code":{"pattern":"if \\(false\\)"}}}}}},
    {"if":{"properties":{"language":{"const":"rust"},"mutation":{"properties":{"operator":{"const":"raises-none-to-value-error-v1"}},"required":["operator"]}},"required":["language","mutation"]},"then":{"properties":{"source":{"properties":{"code":{"pattern":"if false"}}}}}},
    {"if":{"properties":{"language":{"const":"go"},"mutation":{"properties":{"operator":{"const":"raises-none-to-value-error-v1"}},"required":["operator"]}},"required":["language","mutation"]},"then":{"properties":{"source":{"properties":{"code":{"pattern":"if false"}}}}}},
    {"if":{"properties":{"language":{"const":"python"},"mutation":{"properties":{"operator":{"const":"default-value-one-to-two-v1"}},"required":["operator"]}},"required":["language","mutation"]},"then":{"properties":{"source":{"properties":{"code":{"pattern":"item=1"}}}}}},
    {"if":{"properties":{"language":{"const":"java"},"mutation":{"properties":{"operator":{"const":"default-value-one-to-two-v1"}},"required":["operator"]}},"required":["language","mutation"]},"then":{"properties":{"source":{"properties":{"code":{"pattern":"orElse\\(1\\)"}}}}}},
    {"if":{"properties":{"language":{"const":"typescript"},"mutation":{"properties":{"operator":{"const":"default-value-one-to-two-v1"}},"required":["operator"]}},"required":["language","mutation"]},"then":{"properties":{"source":{"properties":{"code":{"pattern":"item = 1"}}}}}},
    {"if":{"properties":{"language":{"const":"rust"},"mutation":{"properties":{"operator":{"const":"default-value-one-to-two-v1"}},"required":["operator"]}},"required":["language","mutation"]},"then":{"properties":{"source":{"properties":{"code":{"pattern":"unwrap_or\\(1\\)"}}}}}},
    {"if":{"properties":{"language":{"const":"go"},"mutation":{"properties":{"operator":{"const":"default-value-one-to-two-v1"}},"required":["operator"]}},"required":["language","mutation"]},"then":{"properties":{"source":{"properties":{"code":{"pattern":"defaultValue\\(1\\)"}}}}}},
    {"if":{"properties":{"language":{"const":"python"},"mutation":{"properties":{"operator":{"const":"cardinality-one-to-two-v1"}},"required":["operator"]}},"required":["language","mutation"]},"then":{"properties":{"source":{"properties":{"code":{"pattern":"items\\s*=\\s*\\[1\\]"}}}}}},
    {"if":{"properties":{"language":{"const":"java"},"mutation":{"properties":{"operator":{"const":"cardinality-one-to-two-v1"}},"required":["operator"]}},"required":["language","mutation"]},"then":{"properties":{"source":{"properties":{"code":{"pattern":"items\\s*=\\s*\\{1\\}"}}}}}},
    {"if":{"properties":{"language":{"const":"typescript"},"mutation":{"properties":{"operator":{"const":"cardinality-one-to-two-v1"}},"required":["operator"]}},"required":["language","mutation"]},"then":{"properties":{"source":{"properties":{"code":{"pattern":"items\\s*=\\s*\\[1\\]"}}}}}},
    {"if":{"properties":{"language":{"const":"rust"},"mutation":{"properties":{"operator":{"const":"cardinality-one-to-two-v1"}},"required":["operator"]}},"required":["language","mutation"]},"then":{"properties":{"source":{"properties":{"code":{"pattern":"items\\s*=\\s*\\[1\\]"}}}}}},
    {"if":{"properties":{"language":{"const":"go"},"mutation":{"properties":{"operator":{"const":"cardinality-one-to-two-v1"}},"required":["operator"]}},"required":["language","mutation"]},"then":{"properties":{"source":{"properties":{"code":{"pattern":"items\\s*:=\\s*\\[\\]int\\{1\\}"}}}}}},
    {"if":{"properties":{"language":{"const":"python"},"mutation":{"properties":{"operator":{"const":"state-change-before-to-after-v1"}},"required":["operator"]}},"required":["language","mutation"]},"then":{"properties":{"source":{"properties":{"code":{"pattern":"state\\s*=\\s*not state"}}}}}},
    {"if":{"properties":{"language":{"const":"java"},"mutation":{"properties":{"operator":{"const":"state-change-before-to-after-v1"}},"required":["operator"]}},"required":["language","mutation"]},"then":{"properties":{"source":{"properties":{"code":{"pattern":"state\\s*=\\s*!state"}}}}}},
    {"if":{"properties":{"language":{"const":"typescript"},"mutation":{"properties":{"operator":{"const":"state-change-before-to-after-v1"}},"required":["operator"]}},"required":["language","mutation"]},"then":{"properties":{"source":{"properties":{"code":{"pattern":"state\\s*=\\s*!state"}}}}}},
    {"if":{"properties":{"language":{"const":"rust"},"mutation":{"properties":{"operator":{"const":"state-change-before-to-after-v1"}},"required":["operator"]}},"required":["language","mutation"]},"then":{"properties":{"source":{"properties":{"code":{"pattern":"state\\s*=\\s*!state"}}}}}},
    {"if":{"properties":{"language":{"const":"go"},"mutation":{"properties":{"operator":{"const":"state-change-before-to-after-v1"}},"required":["operator"]}},"required":["language","mutation"]},"then":{"properties":{"source":{"properties":{"code":{"pattern":"state\\s*=\\s*!state"}}}}}}
  ],
  "type": "object"
}
