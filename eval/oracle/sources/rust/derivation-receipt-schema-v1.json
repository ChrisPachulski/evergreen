{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema_version": {"const": 1},
    "kind": {"const": "evergreen-rust-derivation-receipt"},
    "generator_id": {"const": "rust-const-usize-return-v1"},
    "generator_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "receipt_schema_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "source_id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$"},
    "repository_path": {"type": "string", "minLength": 1},
    "input_path": {"type": "string", "minLength": 1},
    "blob_oid": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "blob_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "span_start": {"type": "integer", "minimum": 0},
    "span_end": {"type": "integer", "minimum": 1},
    "span_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "oracle_kind": {"const": "return-value"},
    "observed_value": {"const": 1},
    "wrapper_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "documentation_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "derivation_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  },
  "required": [
    "schema_version",
    "kind",
    "generator_id",
    "generator_sha256",
    "receipt_schema_sha256",
    "source_id",
    "repository_path",
    "input_path",
    "blob_oid",
    "blob_sha256",
    "span_start",
    "span_end",
    "span_sha256",
    "oracle_kind",
    "observed_value",
    "wrapper_sha256",
    "documentation_sha256",
    "derivation_sha256"
  ]
}
