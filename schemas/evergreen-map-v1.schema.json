{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://evergreen.local/schemas/evergreen-map-v1.schema.json",
  "title": "Evergreen source-to-document map v1",
  "description": "Additive candidate mappings only; maps cannot suppress discovery or express findings, verdicts, or commands.",
  "type": "object",
  "additionalProperties": false,
  "x-duplicateKeyBehavior": "reject-file",
  "x-impactInputBounds": {
    "changedPaths": {"maxItems": 10000, "overLimit": "retain-caller-order-prefix"},
    "evidence": {"maxItems": 10000, "overLimit": "retain-caller-order-prefix"}
  },
  "required": ["version", "maps"],
  "properties": {
    "version": {"const": 1},
    "maps": {
      "type": "array",
      "maxItems": 1000,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "x-duplicateKeyBehavior": "reject-containing-map",
        "required": ["sources", "docs"],
        "properties": {
          "sources": {
            "type": "array",
            "minItems": 1,
            "maxItems": 100,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 4096,
              "pattern": "^(?!/)(?!.*\\\\)(?!.*(?:^|/)\\.{1,2}(?:/|$))(?!.*//)(?!.*[\\u0000-\\u001F\\u007F])(?!.*(?:^|/)[^/]+\\*\\*)(?!.*\\*\\*[^/]+(?:/|$))[^/]+(?:/[^/]+)*$",
              "description": "Normalized repository-relative segment-aware glob. *, ?, and character classes match within one path segment; ** as a complete segment matches across zero or more segments.",
              "x-maxUtf8Bytes": 4096,
              "x-globSemantics": "segment-aware",
              "x-runtimeConstraints": {"balancedBracketClasses": true}
            }
          },
          "docs": {
            "type": "array",
            "minItems": 1,
            "maxItems": 100,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 4096,
              "pattern": "^(?!/)(?!.*\\\\)(?!.*(?:^|/)\\.{1,2}(?:/|$))(?!.*//)(?!.*[\\u0000-\\u001F\\u007F])[^/]+(?:/[^/]+)*$",
              "description": "Normalized repository-relative document path, resolved within the repository at runtime.",
              "x-maxUtf8Bytes": 4096,
              "x-repositoryContainment": "resolved-within-repo"
            }
          }
        }
      }
    }
  }
}
