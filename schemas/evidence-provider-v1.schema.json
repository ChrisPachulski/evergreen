{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://evergreen.local/schemas/evidence-provider-v1.schema.json",
  "title": "Evergreen passive evidence provider v1",
  "description": "candidate-only mechanical evidence; records cannot express findings or verdicts.",
  "type": "array",
  "maxItems": 10000,
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "provider", "version", "type", "path", "line", "span", "symbol",
      "old", "current", "confidence"
    ],
    "properties": {
      "provider": {"type": "string", "minLength": 1, "maxLength": 256, "x-maxUtf8Bytes": 256},
      "version": {"type": "string", "minLength": 1, "maxLength": 256, "x-maxUtf8Bytes": 256},
      "type": {"type": "string", "minLength": 1, "maxLength": 256, "x-maxUtf8Bytes": 256},
      "path": {
        "type": "string",
        "minLength": 1,
        "maxLength": 4096,
        "pattern": "^(?!/)(?!.*\\\\)(?!.*(?:^|/)\\.{1,2}(?:/|$))(?!.*//)(?!.*[\\u0000-\\u001F\\u007F])[^/]+(?:/[^/]+)*$",
        "description": "normalized POSIX repository-relative path; runtime resolution must remain inside the repository and reject symlink escapes",
        "x-maxUtf8Bytes": 4096,
        "x-repositoryContainment": "resolved-within-repo"
      },
      "line": {"type": "integer", "minimum": 1, "maximum": 2147483647},
      "span": {"type": ["integer", "null"], "minimum": 1, "maximum": 2147483647},
      "symbol": {"type": ["string", "null"], "minLength": 1, "maxLength": 8192, "x-maxUtf8Bytes": 8192},
      "old": {"type": ["string", "null"], "minLength": 1, "maxLength": 8192, "x-maxUtf8Bytes": 8192},
      "current": {"type": ["string", "null"], "minLength": 1, "maxLength": 8192, "x-maxUtf8Bytes": 8192},
      "confidence": {"enum": ["deterministic", "advisory"]},
      "metadata": {"type": "object", "x-maxUtf8Bytes": 16384, "x-maxDepth": 8}
    }
  }
}
